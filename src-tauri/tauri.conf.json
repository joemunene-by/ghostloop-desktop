{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ghostloop",
  "version": "0.2.0",
  "identifier": "by.joemunene.ghostloop.desktop",
  "build": {
    "beforeDevCommand": "cd ../ghostloop-ui && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../ghostloop-ui && npm run build && npm run start &",
    "frontendDist": "../ghostloop-ui/.next/static"
  },
  "app": {
    "windows": [
      {
        "title": "ghostloop · control",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Joe Munene",
    "shortDescription": "Native desktop control for ghostloop robots.",
    "longDescription": "Drive any robot through the ghostloop safety pipeline. Native gamepad input, sidecar Python runtime, embedded MuJoCo viewer."
  },
  "plugins": {
    "notification": {}
  }
}
